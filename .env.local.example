# Supabase
# Obtienes URL y anon key en: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Solo para uso en servidor (server actions, route handlers, scripts).
# NUNCA expongas esta key al cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TMDB API key v3 (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your-tmdb-api-key

# OMDb API key (opcional). Si está presente, Discover muestra badges de
# Rotten Tomatoes e IMDb en cada card. Gratis en:
# https://www.omdbapi.com/apikey.aspx (1000 requests/día)
OMDB_API_KEY=

# Loading demo delay (opcional). Demora cada página protegida N milisegundos
# para que la LoadingScreen sea visible durante la navegación normal.
# Útil solo para demos/design review. Dejar vacío en producción.
LOADING_DEMO_MS=

# Web Push (VAPID). Necesarias para mandar push notifications.
# Genera un par nuevo con:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# La pública (NEXT_PUBLIC_) la usa el cliente para suscribirse.
# La privada firma cada push desde el servidor — nunca exponerla.
# VAPID_SUBJECT debe ser un mailto: con un correo válido al que los push
# services puedan escribir si hay un problema con tus envíos.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
